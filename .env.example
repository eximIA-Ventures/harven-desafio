# Database (Supabase Postgres via pooler)
DATABASE_URL=postgresql://postgres.xxx:password@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Session secret (min 32 chars, REQUIRED)
SESSION_SECRET=your-secret-key-here-min-32-chars

# brapi.dev token (optional — improves rate limits)
BRAPI_TOKEN=
